rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
//  Licorice Herbals — Firebase Storage Security Rules
//
//  Buckets used:
//    • product images   — uploaded by admin only
//    • review images    — uploaded by authenticated users (their own reviews)
//    • whatsapp proofs  — uploaded by authenticated users (their own orders)
//    • blog covers      — uploaded by admin only
// ─────────────────────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email.matches('.*@licoriceherbal\\.in');
    }

    function isSizeOk(maxMB) {
      return request.resource.size <= maxMB * 1024 * 1024;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // ─── Product images ───────────────────────────────────────────────────────
    // Only admins upload; everyone reads.

    match /products/{allPaths=**} {
      allow read:   if true;
      allow write:  if isAdmin() && isImage() && isSizeOk(5);
    }

    // ─── Blog covers ──────────────────────────────────────────────────────────

    match /blogs/{allPaths=**} {
      allow read:   if true;
      allow write:  if isAdmin() && isImage() && isSizeOk(5);
    }

    // ─── Category / Concern images ────────────────────────────────────────────

    match /categories/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin() && isImage() && isSizeOk(2);
    }

    // ─── Review images ────────────────────────────────────────────────────────
    // Authenticated users can upload images to their own review folder.
    // Path convention: reviews/{userId}/{filename}

    match /reviews/{userId}/{filename} {
      allow read:   if true;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isImage()
        && isSizeOk(5);
      allow delete: if isSignedIn() && request.auth.uid == userId;
      allow update: if false;
    }

    // ─── WhatsApp payment proofs ──────────────────────────────────────────────
    // Authenticated users upload proof for their own orders.
    // Path convention: payment-proofs/{userId}/{filename}

    match /payment-proofs/{userId}/{filename} {
      allow read:   if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isImage()
        && isSizeOk(10);
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ─── Return images ────────────────────────────────────────────────────────
    // Path convention: returns/{userId}/{orderId}/{filename}

    match /returns/{userId}/{orderId}/{filename} {
      allow read:   if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isImage()
        && isSizeOk(10);
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ─── Admin uploads (generic) ──────────────────────────────────────────────

    match /admin/{allPaths=**} {
      allow read:   if isAdmin();
      allow write:  if isAdmin() && isSizeOk(20);
    }

    // ─── Catch-all: deny everything else ─────────────────────────────────────

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
